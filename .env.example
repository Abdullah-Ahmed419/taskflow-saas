# ─────────────────────────────────────────────────────────────────────────────
# TaskFlow SaaS — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── Database ──────────────────────────────────────────────────────────────────
# Railway sets this automatically when you add a PostgreSQL service.
# For local dev, use SQLite:  sqlite:///taskflow_dev.db
DATABASE_URL=postgresql://user:password@host:5432/taskflow

# ── App URL (used for OAuth callbacks and emails) ─────────────────────────────
APP_URL=https://your-app.up.railway.app

# ── Google OAuth (optional — email/password login works without this) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your real password).
# See: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=TaskFlow <noreply@taskflow.app>

# ── SaaS limits ───────────────────────────────────────────────────────────────
FREE_TASK_LIMIT=10

# ── Stripe (optional — add when you're ready to charge) ──────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
