{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "flask db upgrade && gunicorn 'app:create_app()' --bind 0.0.0.0:$PORT --workers 2 --timeout 120 --access-logfile -",
    "healthcheckPath": "/login",
    "restartPolicyType": "ON_FAILURE"
  }
}
